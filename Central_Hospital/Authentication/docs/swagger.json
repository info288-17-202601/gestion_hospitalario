{
    "swagger": "2.0",
    "info": {
        "description": "API for Hospital user authentication (Dual Login).",
        "title": "Authentication Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:7050",
    "basePath": "/api/v1",
    "paths": {
        "/auth/login/classic": {
            "post": {
                "description": "Authenticates a user with RUT and password, returns JWT token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "authentication"
                ],
                "summary": "Login via RUT and Password",
                "parameters": [
                    {
                        "description": "Login credentials",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schemas.LoginClassicRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully authenticated",
                        "schema": {
                            "$ref": "#/definitions/schemas.TokenResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/auth/login/rfid": {
            "post": {
                "description": "Authenticates a user using RFID card UID and PIN, returns JWT token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "authentication"
                ],
                "summary": "Login via RFID and PIN",
                "parameters": [
                    {
                        "description": "RFID credentials",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schemas.LoginRFIDRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully authenticated",
                        "schema": {
                            "$ref": "#/definitions/schemas.TokenResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "schemas.LoginClassicRequest": {
            "type": "object",
            "required": [
                "password",
                "rut"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "rut": {
                    "type": "string"
                }
            }
        },
        "schemas.LoginRFIDRequest": {
            "type": "object",
            "required": [
                "pin",
                "uid"
            ],
            "properties": {
                "pin": {
                    "type": "string"
                },
                "uid": {
                    "type": "string"
                }
            }
        },
        "schemas.TokenResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "token_type": {
                    "type": "string"
                },
                "user": {
                    "$ref": "#/definitions/schemas.UserResponse"
                }
            }
        },
        "schemas.UserResponse": {
            "type": "object",
            "properties": {
                "department_id": {
                    "type": "integer"
                },
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                }
            }
        }
    }
}